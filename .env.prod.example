# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://toolbox.watdev.eu

# ── Domain (used by Traefik labels) ────────────────────────────────────────────
DOMAIN=toolbox.watdev.eu

# ── Let's Encrypt ──────────────────────────────────────────────────────────────
ACME_EMAIL=admin@watdev.eu

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=watdev
DB_USER=watdev_user
DB_PASS=change-me

# ── Uploads ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/shared/uploads

# ── Keycloak ───────────────────────────────────────────────────────────────────
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_REALM=WATDEV
KEYCLOAK_CLIENT_ID=watdev-toolbox
KEYCLOAK_CLIENT_SECRET=change-me

# ── pgAdmin ────────────────────────────────────────────────────────────────────
# Emergency / bootstrap admin account (not used once Keycloak is working)
PGADMIN_DEFAULT_EMAIL=admin@watdev.eu
PGADMIN_DEFAULT_PASSWORD=change-me

# ── Build metadata (set by CI) ─────────────────────────────────────────────────
GIT_SHA=unknown
BUILD_DATE=unknown
